# --- Existing (already configured, no changes needed) ---
GOOGLE_SHEET_ID=
GOOGLE_API_KEY=
OFFICER_PIN=

# --- New for this phase ---

# Neon Postgres connection string. From your Neon project dashboard:
# Connect > select "Pooled connection" > copy the full postgres:// URL.
DATABASE_URL=

# Google service account credentials, used only for WRITING to the Sheet
# (the existing GOOGLE_API_KEY above stays as-is and continues to handle
# all reads). From Google Cloud Console > IAM & Admin > Service Accounts:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# Clash of Clans API key (already obtained, whitelisted to the RoyaleAPI
# proxy IP rather than your own).
COC_API_KEY=
