# Copy this to .env.local for local development, and set the same
# variables in Vercel's Project Settings → Environment Variables for
# production.

# The Google Sheet's ID (the long string in its URL between /d/ and /edit).
GOOGLE_SHEET_ID=

# A Google Cloud API key with the Sheets API enabled, restricted to that API.
# The sheet itself must be shared as "Anyone with the link can view" since
# this is a read-only API key, not a service account.
GOOGLE_API_KEY=

# Shared passcode officers enter to unlock the manual roster-refresh control.
# Anyone who knows this PIN can only force an early cache refresh — it does
# not grant write access to the sheet or any other data.
OFFICER_PIN=
